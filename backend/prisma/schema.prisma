generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  username      String    @unique
  email         String    @unique
  password      String?
  profile_image String?
  bio           String?
  skills        String[]
  github_url    String?
  is_public     Boolean   @default(true)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  ideas         Idea[]
  votes         Vote[]
  comments      Comment[]
  memberships   ProjectMember[]
  sent_requests CollaborationRequest[] @relation("SentRequests")
  recv_requests CollaborationRequest[] @relation("ReceivedRequests")
  notifications Notification[]
}

model Idea {
  id           String    @id @default(uuid())
  title        String
  description  String
  tags         String[]
  media_url    String?
  media_type   String?   // 'image' or 'video'
  is_anonymous Boolean   @default(false)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  owner_id     String
  owner        User      @relation(fields: [owner_id], references: [id])

  votes        Vote[]
  comments     Comment[]
  requests     CollaborationRequest[]
  project      Project?
}

model Vote {
  id         String   @id @default(uuid())
  value      Int      // 1 for upvote, -1 for downvote
  created_at DateTime @default(now())

  user_id    String
  user       User     @relation(fields: [user_id], references: [id])
  
  idea_id    String
  idea       Idea     @relation(fields: [idea_id], references: [id])

  @@unique([user_id, idea_id])
}

model Comment {
  id         String   @id @default(uuid())
  content    String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user_id    String
  user       User     @relation(fields: [user_id], references: [id])

  idea_id    String
  idea       Idea     @relation(fields: [idea_id], references: [id])
}

model CollaborationRequest {
  id           String   @id @default(uuid())
  request_type String   // 'JOIN_REQUEST' or 'INVITE'
  status       String   @default("PENDING") // 'PENDING', 'ACCEPTED', 'REJECTED'
  message      String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  sender_id    String
  sender       User     @relation("SentRequests", fields: [sender_id], references: [id])

  receiver_id  String
  receiver     User     @relation("ReceivedRequests", fields: [receiver_id], references: [id])

  idea_id      String
  idea         Idea     @relation(fields: [idea_id], references: [id])
}

model Project {
  id         String   @id @default(uuid())
  status     String   @default("ACTIVE") // 'ACTIVE', 'COMPLETED', 'PAUSED'
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  idea_id    String   @unique
  idea       Idea     @relation(fields: [idea_id], references: [id])

  members    ProjectMember[]
}

model ProjectMember {
  id         String   @id @default(uuid())
  role       String   @default("MEMBER") // 'ADMIN', 'MEMBER', 'CONTRIBUTOR'
  joined_at  DateTime @default(now())

  project_id String
  project    Project  @relation(fields: [project_id], references: [id])

  user_id    String
  user       User     @relation(fields: [user_id], references: [id])

  @@unique([project_id, user_id])
}

model Notification {
  id         String   @id @default(uuid())
  type       String   // 'LIKE', 'COMMENT', 'COLLAB_REQUEST', etc.
  content    String
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())

  user_id    String
  user       User     @relation(fields: [user_id], references: [id])
}
